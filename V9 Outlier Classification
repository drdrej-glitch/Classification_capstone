    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "def detect_variable_types(df, target_col=None):\n",
    "    \"\"\"Automatically detect variable types in a DataFrame\"\"\"\n",
    "    types = {}\n",
    "    \n",
    "    for col in df.columns:\n",
    "        if col == target_col:\n",
    "            types[col] = 'target'\n",
    "        elif pd.api.types.is_datetime64_any_dtype(df[col]):\n",
    "            types[col] = 'datetime'\n",
    "        elif pd.api.types.is_numeric_dtype(df[col]):\n",
    "            if df[col].nunique() == 2:\n",
    "                types[col] = 'binary'\n",
    "            else:\n",
    "                types[col] = 'numerical'\n",
    "        elif df[col].nunique() < 20:  # Threshold for categorical\n",
    "            types[col] = 'categorical'\n",
    "        elif df[col].dtype == 'object':\n",
    "            # Check if it's text (long strings) or categorical\n",
    "            avg_length = df[col].astype(str).str.len().mean()\n",
    "            if avg_length > 50:\n",
    "                types[col] = 'text'\n",
    "            else:\n",
    "                types[col] = 'categorical'\n",
    "    \n",
    "    return types\n",
    "\n",
    "# Run detection on our dataset\n",
    "auto_types = detect_variable_types(df, target_col='Conversion')\n",
    "\n",
    "# Display as a clean table\n",
    "type_df = pd.DataFrame(list(auto_types.items()), columns=['Feature', 'Detected Type'])\n",
