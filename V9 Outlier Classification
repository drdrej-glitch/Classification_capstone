    "    upper_bound = Q3 + 1.5 * IQR\n",
    "    outliers = data[(data[column] < lower_bound) | (data[column] > upper_bound)]\n",
    "    return outliers, lower_bound, upper_bound\n",
    "\n",
    "print('=' * 65)\n",
    "print('IQR OUTLIER DETECTION (1.5 × IQR)')\n",
    "print('=' * 65)\n",
    "iqr_results = {}\n",
    "for col in numeric_cols:\n",
    "    outliers, lower, upper = find_iqr_outliers(df, col)\n",
    "    iqr_results[col] = len(outliers)\n",
    "    flag = '⚠️' if len(outliers) > 0 else '✅'\n",
    "    print(f\"  {flag} {col:.<30s} {len(outliers):>5} outliers  range: [{lower:.1f}, {upper:.1f}]\")\n",
    "\n",
    "total_iqr = sum(iqr_results.values())\n",
    "print(f\"\\nTotal IQR flags: {total_iqr}\")"
   ]
