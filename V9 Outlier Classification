    "# Z-Score outlier detection (threshold = 3 standard deviations)\n",
    "def find_zscore_outliers(data, column, threshold=3):\n",
    "    mean = data[column].mean()\n",
    "    std = data[column].std()\n",
    "    z_scores = abs((data[column] - mean) / std)\n",
    "    outliers = data[z_scores > threshold]\n",
    "    return outliers\n",
