    "# Pipeline A — Linear models (with scaling)\n",
    "num_pipe_linear = Pipeline([\n",
    "    ('imputer', SimpleImputer(strategy='median')),\n",
    "    ('scaler', RobustScaler())\n",
    "])\n",
    "\n",
    "cat_pipe = Pipeline([\n",
    "    ('imputer', SimpleImputer(strategy='most_frequent')),\n",
    "    ('encoder', OneHotEncoder(handle_unknown='ignore', sparse_output=False, drop='first'))\n",
    "])\n",
    "\n",
    "full_pipeline_linear = Pipeline([\n",
    "    ('engineer', FeatureEngineer()),\n",
    "    ('preprocess', ColumnTransformer([\n",
    "        ('num', num_pipe_linear, num_cols_engineered),\n",
    "        ('cat', cat_pipe, cat_cols)\n",
    "    ], remainder='drop'))\n",
    "])\n",
    "\n",
    "# Pipeline B — Tree models (no scaling)\n",
    "num_pipe_tree = Pipeline([\n",
    "    ('imputer', SimpleImputer(strategy='median'))\n",
    "])\n",
    "\n",
    "full_pipeline_tree = Pipeline([\n",
    "    ('engineer', FeatureEngineer()),\n",
    "    ('preprocess', ColumnTransformer([\n",
    "        ('num', num_pipe_tree, num_cols_engineered),\n",
    "        ('cat', cat_pipe, cat_cols)\n",
    "    ], remainder='drop'))\n",
    "])\n",
    "\n",
