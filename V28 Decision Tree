    "# Encode categorical features\n",
    "from sklearn.preprocessing import OneHotEncoder\n",
    "import pandas as pd\n",
    "\n",
    "def encode_categorical_features(df, categorical_cols, encoding_strategy='onehot'):\n",
    "    \"\"\"Encode categorical variables based on strategy.\"\"\"\n",
    "    df_encoded = df.copy()\n",
    "    \n",
    "    for col in categorical_cols:\n",
    "        unique_count = df[col].nunique()\n",
    "        \n",
    "        if encoding_strategy == 'onehot' and unique_count <= 10:\n",
    "            encoder = OneHotEncoder(sparse_output=False, handle_unknown='ignore', drop='first')\n",
    "            encoded_cols = encoder.fit_transform(df[[col]])\n",
    "            col_names = [f\"{col}_{cat}\" for cat in encoder.categories_[0][1:]]  # skip dropped first\n",
    "            encoded_df = pd.DataFrame(encoded_cols, columns=col_names, index=df.index)\n",
    "            df_encoded = pd.concat([df_encoded.drop(col, axis=1), encoded_df], axis=1)\n",
    "            \n",
    "        elif encoding_strategy == 'label':\n",
    "            from sklearn.preprocessing import LabelEncoder\n",
    "            encoder = LabelEncoder()\n",
    "            df_encoded[col] = encoder.fit_transform(df[col].astype(str))\n",
    "    \n",
    "    return df_encoded\n",
    "\n",
    "# Columns to encode (excluding constants which will be dropped)\n",
    "cols_to_encode = ['Gender', 'CampaignChannel', 'CampaignType']\n",
    "\n",
    "# Apply one-hot encoding with drop='first' to avoid multicollinearity\n",
    "df_encoded = encode_categorical_features(df, cols_to_encode, encoding_strategy='onehot')\n",
    "\n",
    "# Drop constants and identifier\n",
    "df_encoded = df_encoded.drop(columns=['CustomerID', 'AdvertisingPlatform', 'AdvertisingTool'], errors='ignore')\n",
