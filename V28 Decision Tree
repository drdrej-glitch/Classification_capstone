   "source": [
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.preprocessing import RobustScaler, OneHotEncoder, FunctionTransformer\n",
    "from sklearn.impute import SimpleImputer\n",
    "from sklearn.base import BaseEstimator, TransformerMixin\n",
    "import numpy as np\n",
    "import joblib\n",
    "\n",
    "class FeatureEngineer(BaseEstimator, TransformerMixin):\n",
    "    \"\"\"Custom transformer that creates all engineered features.\"\"\"\n",
    "    \n",
    "    def fit(self, X, y=None):\n",
    "        return self\n",
    "    \n",
    "    def transform(self, X):\n",
    "        X = X.copy()\n",
    "        \n",
    "        # Consistency fixes\n",
    "        X['EmailClicks'] = np.minimum(X['EmailClicks'], X['EmailOpens'])\n",
    "        X['PagesPerVisit'] = np.where(X['WebsiteVisits'] == 0, 0, X['PagesPerVisit'])\n",
    "        \n",
    "        # Domain features\n",
    "        X['EmailEngagementRatio'] = np.where(\n",
    "            X['EmailOpens'] > 0, X['EmailClicks'] / X['EmailOpens'], 0\n",
    "        )\n",
    "        X['TotalEngagement'] = X['WebsiteVisits'] + X['EmailOpens'] + X['SocialShares']\n",
    "        X['AdEfficiency'] = np.where(\n",
    "            X['WebsiteVisits'] > 0, X['AdSpend'] / X['WebsiteVisits'], X['AdSpend']\n",
    "        )\n",
    "        X['SpendPerPurchase'] = np.where(\n",
    "            X['PreviousPurchases'] > 0, X['AdSpend'] / X['PreviousPurchases'], X['AdSpend']\n",
    "        )\n",
    "        \n",
    "        # Log transforms\n",
    "        for col in ['Income', 'AdSpend', 'LoyaltyPoints']:\n",
    "            X[f'{col}_log'] = np.log1p(X[col])\n",
    "        \n",
    "        # Replace infinities\n",
    "        X = X.replace([np.inf, -np.inf], 0)\n",
    "        \n",
    "        return X\n",
    "\n",
    "# Define column groups AFTER feature engineering\n",
    "num_cols_engineered = [\n",
    "    'Age', 'Income', 'AdSpend', 'ClickThroughRate', 'ConversionRate',\n",
    "    'WebsiteVisits', 'PagesPerVisit', 'TimeOnSite', 'SocialShares',\n",
    "    'EmailOpens', 'EmailClicks', 'PreviousPurchases', 'LoyaltyPoints',\n",
    "    'EmailEngagementRatio', 'TotalEngagement', 'AdEfficiency',\n",
    "    'SpendPerPurchase', 'Income_log', 'AdSpend_log', 'LoyaltyPoints_log'\n",
    "]\n",
    "\n",
    "cat_cols = ['Gender', 'CampaignChannel', 'CampaignType']\n",
    "\n",
    "print(\"Pipeline column configuration:\")\n",
    "print(f\"  Numerical: {len(num_cols_engineered)} features\")\n",
    "print(f\"  Categorical: {len(cat_cols)} features\")"
   ]
