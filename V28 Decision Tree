    "# 2. Cramér's V — categorical features vs Conversion\n",
    "def cramers_v(col1, col2):\n",
    "    \"\"\"Calculate Cramér's V for two categorical variables.\"\"\"\n",
    "    contingency = pd.crosstab(col1, col2)\n",
    "    chi2 = chi2_contingency(contingency)[0]\n",
    "    n = len(col1)\n",
    "    min_dim = min(contingency.shape) - 1\n",
    "    return np.sqrt(chi2 / (n * min_dim)) if min_dim > 0 else 0\n",
    "\n",
    "print('=' * 60)\n",
    "print(\"CRAMÉR'S V (categorical vs Conversion)\")\n",
    "print('=' * 60)\n",
    "\n",
    "cat_features = ['Gender', 'CampaignChannel', 'CampaignType']\n",
    "for col in cat_features:\n",
    "    v = cramers_v(df[col], df['Conversion'])\n",
    "    strength = 'Strong' if v > 0.3 else 'Moderate' if v > 0.1 else 'Weak'\n",
    "    print(f\"  {col:.<30s} V={v:.4f}  ({strength})\")"
   ]
