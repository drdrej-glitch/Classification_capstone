    "# 1. Email engagement ratio (after capping clicks at opens)\n",
    "df_eng['EmailClicks_capped'] = np.minimum(df_eng['EmailClicks'], df_eng['EmailOpens'])\n",
    "df_eng['EmailEngagementRatio'] = np.where(\n",
    "    df_eng['EmailOpens'] > 0,\n",
    "    df_eng['EmailClicks_capped'] / df_eng['EmailOpens'],\n",
    "    0\n",
    ")\n",
    "\n",
    "# 2. Pages per visit consistency fix\n",
    "df_eng['PagesPerVisit_fixed'] = np.where(\n",
    "    df_eng['WebsiteVisits'] == 0, 0, df_eng['PagesPerVisit']\n",
    ")\n",
    "\n",
    "# 3. Total engagement score (combines web + email + social signals)\n",
    "df_eng['TotalEngagement'] = (\n",
    "    df_eng['WebsiteVisits'] +\n",
    "    df_eng['EmailOpens'] +\n",
    "    df_eng['SocialShares']\n",
    ")\n",
    "\n",
    "# 4. Ad efficiency (spend per website visit)\n",
    "df_eng['AdEfficiency'] = np.where(\n",
    "    df_eng['WebsiteVisits'] > 0,\n",
    "    df_eng['AdSpend'] / df_eng['WebsiteVisits'],\n",
    "    df_eng['AdSpend']\n",
    ")\n",
    "\n",
    "# 5. Spend per previous purchase (customer value signal)\n",
    "df_eng['SpendPerPurchase'] = np.where(\n",
    "    df_eng['PreviousPurchases'] > 0,\n",
    "    df_eng['AdSpend'] / df_eng['PreviousPurchases'],\n",
    "    df_eng['AdSpend']\n",
    ")\n",
    "\n",
    "new_features = ['EmailEngagementRatio', 'PagesPerVisit_fixed', 'TotalEngagement',\n",
