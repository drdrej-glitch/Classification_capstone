    "# Leakage detection scan\n",
    "def check_for_leakage(df, target_col, feature_cols):\n",
    "    \"\"\"Check for potential data leakage across three dimensions.\"\"\"\n",
    "    leakage_report = {}\n",
    "    \n",
    "    for col in feature_cols:\n",
    "        # 1. High correlation with target\n",
    "        if df[col].dtype in ['int64', 'float64']:\n",
    "            correlation = df[col].corr(df[target_col])\n",
    "            if abs(correlation) > 0.95:\n",
    "                leakage_report[col] = f\"🔴 HIGH CORRELATION with target: {correlation:.3f}\"\n",
    "            elif abs(correlation) > 0.80:\n",
    "                leakage_report[col] = f\"🟠 MODERATE CORRELATION with target: {correlation:.3f}\"\n",
    "        \n",
    "        # 2. Suspicious naming patterns\n",
    "        if any(word in col.lower() for word in ['target', 'label', 'outcome', 'result', 'future', 'next', 'after']):\n",
    "            leakage_report[col] = \"🔴 SUSPICIOUS NAME — potentially target-derived or future-looking\"\n",
    "    \n",
    "    return leakage_report\n",
    "\n",
    "feature_cols = [c for c in df.columns if c not in ['Conversion', 'CustomerID', 'AdvertisingPlatform', 'AdvertisingTool']]\n",
    "\n",
    "# Filter to numeric features only for correlation check\n",
    "numeric_feature_cols = [c for c in feature_cols if df[c].dtype in ['int64', 'float64']]\n",
    "\n",
    "print('=' * 60)\n",
    "print('LEAKAGE SCAN — FEATURE CORRELATION WITH TARGET')\n",
    "print('=' * 60)\n",
    "\n",
    "# Compute correlations on numeric columns only\n",
    "correlations = df[numeric_feature_cols].corrwith(df['Conversion']).abs().sort_values(ascending=False)\n",
    "for col, corr in correlations.items():\n",
    "    if corr > 0.95:\n",
    "        flag = '🔴 LEAKAGE RISK'\n",
    "    elif corr > 0.80:\n",
    "        flag = '🟠 REVIEW'\n",
    "    elif corr > 0.50:\n",
    "        flag = '🟡 MODERATE'\n",
    "    else:\n",
    "        flag = '✅'\n",
    "    print(f\"  {flag} {col:.<30s} {corr:.4f}\")\n",
    "\n",
    "# Note non-numeric columns skipped\n",
    "non_numeric = [c for c in feature_cols if c not in numeric_feature_cols]\n",
    "if non_numeric:\n",
    "    print(f\"\\n  Categorical columns (not applicable for correlation): {non_numeric}\")\n",
    "\n",
    "# Run full scan\n",
    "report = check_for_leakage(df, 'Conversion', feature_cols)\n",
    "print(f\"\\n{'=' * 60}\")\n",
    "if report:\n",
