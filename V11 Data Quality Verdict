    " \n",
    "# One-hot encoding\n",
    "nominal_cols = ['Body Type', 'Sex', 'Diet', 'Heating Energy Source', 'Transport', 'Vehicle Type']\n",
    "df_encoded = pd.get_dummies(df_work, columns=nominal_cols, drop_first=True)\n",
    " \n",
    "# Scale\n",
    "scaler = StandardScaler()\n",
    "X = scaler.fit_transform(df_encoded)\n",
    "print(f\"Encoded + scaled feature matrix: {X.shape[0]} samples × {X.shape[1]} features\\n\")\n",
    " \n",
    "# --- Hopkins Statistic ---\n",
    "np.random.seed(42)\n",
    " \n",
    "def hopkins_statistic(X, sample_size=200):\n",
    "    n, d = X.shape\n",
    "    sample_idx = np.random.choice(n, sample_size, replace=False)\n",
    "    X_sample = X[sample_idx]\n",
    "    \n",
    "    # Random uniform points in the data space\n",
    "    X_min = X.min(axis=0)\n",
    "    X_max = X.max(axis=0)\n",
    "    X_random = np.random.uniform(X_min, X_max, (sample_size, d))\n",
    "    \n",
    "    # Nearest neighbor distances from random points to data\n",
    "    nn = NearestNeighbors(n_neighbors=1)\n",
    "    nn.fit(X)\n",
    "    u_distances, _ = nn.kneighbors(X_random)\n",
    "    \n",
    "    # Nearest neighbor distances from data points to other data points (exclude self)\n",
    "    nn2 = NearestNeighbors(n_neighbors=2)\n",
    "    nn2.fit(X)\n",
    "    w_distances, _ = nn2.kneighbors(X_sample)\n",
    "    w_distances = w_distances[:, 1]  # second neighbor = nearest excluding self\n",
    "    u_distances = u_distances.flatten()\n",
    "    \n",
    "    H = np.sum(u_distances) / (np.sum(u_distances) + np.sum(w_distances))\n",
    "    return H\n",
    " \n",
    "# Run 10 times for stability\n",
    "hopkins_values = [hopkins_statistic(X, 200) for _ in range(10)]\n",
    " \n",
    "print(\"=== HOPKINS STATISTIC (10 runs) ===\\n\")\n",
    "print(f\"  Mean:  {np.mean(hopkins_values):.4f}\")\n",
    "print(f\"  Std:   {np.std(hopkins_values):.4f}\")\n",
    "print(f\"  Range: {np.min(hopkins_values):.4f} – {np.max(hopkins_values):.4f}\")\n",
    "print(f\"\\nInterpretation scale:\")\n",
    "print(f\"  H ≈ 0.0–0.3  →  Strong cluster structure\")\n",
    "print(f\"  H ≈ 0.3–0.5  →  Moderate cluster tendency\")\n",
    "print(f\"  H ≈ 0.5       →  Random (no cluster structure)\")\n",
    "print(f\"  H > 0.5       →  Uniform / regular (anti-clustering)\")\n",
    "print(f\"\\n{'⚠️ RESULT: H ≈ ' + f'{np.mean(hopkins_values):.2f}' + ' — data shows WEAK clustering tendency'}\")\n",
    "print(f\"\\nThis is consistent with the synthetic data assessment:\")\n",
    "print(f\"uniform categorical distributions + near-zero inter-feature correlations\")\n",
    "print(f\"produce data that is close to uniformly distributed in feature space.\")"
