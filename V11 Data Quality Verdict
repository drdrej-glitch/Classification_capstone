    "print(\"=== LOGICAL CONSISTENCY CHECKS ===\\n\")\n",
    " \n",
    "checks = []\n",
    " \n",
    "# 1. No negative values\n",
    "for c in num_cols_raw:\n",
    "    neg = (df[c] < 0).sum()\n",
    "    status = '✅' if neg == 0 else '❌'\n",
    "    checks.append((f\"No negative values in {c}\", status, f\"{neg} found\"))\n",
    "    \n",
    "# 2. Hours within 0-24\n",
    "for c in ['How Long TV PC Daily Hour', 'How Long Internet Daily Hour']:\n",
    "    invalid = ((df[c] < 0) | (df[c] > 24)).sum()\n",
    "    status = '✅' if invalid == 0 else '❌'\n",
    "    checks.append((f\"{c} within 0-24\", status, f\"{invalid} invalid\"))\n",
    " \n",
    "# 3. Vehicle Type ↔ Transport consistency\n",
    "private_missing_vt = df[(df['Transport'] == 'private') & df['Vehicle Type'].isna()].shape[0]\n",
    "checks.append((\"All private transport has Vehicle Type\", '✅' if private_missing_vt == 0 else '❌', f\"{private_missing_vt} missing\"))\n",
    " \n",
    "nonprivate_has_vt = df[(df['Transport'] != 'private') & df['Vehicle Type'].notna()].shape[0]\n",
    "checks.append((\"No non-private transport has Vehicle Type\", '✅' if nonprivate_has_vt == 0 else '❌', f\"{nonprivate_has_vt} have VT\"))\n",
    " \n",
    "# 4. CarbonEmission > 0\n",
    "invalid_ce = (df['CarbonEmission'] <= 0).sum()\n",
    "checks.append((\"CarbonEmission > 0\", '✅' if invalid_ce == 0 else '❌', f\"{invalid_ce} invalid\"))\n",
    " \n",
    "# 5. Waste Bag Weekly Count >= 1\n",
    "invalid_waste = (df['Waste Bag Weekly Count'] < 1).sum()\n",
    "checks.append((\"Waste Bag Weekly Count ≥ 1\", '✅' if invalid_waste == 0 else '❌', f\"{invalid_waste} invalid\"))\n",
    " \n",
    "# 6. Non-private with distance > 0 (the nuance)\n",
    "non_private = df[df['Transport'] != 'private']\n",
    "non_zero_dist = (non_private['Vehicle Monthly Distance Km'] > 0).sum()\n",
    "checks.append((\"Non-private transport distance = 0\", '⚠️', f\"{non_zero_dist} have distance > 0 (99.5%)\"))\n",
    " \n",
    "for check, status, detail in checks:\n",
    "    print(f\"  {status} {check}: {detail}\")"
