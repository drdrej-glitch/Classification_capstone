    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.cluster import KMeans\n",
    "from sklearn.metrics import silhouette_score, adjusted_rand_score\n",
    " \n",
    "def encode_dataset(df_in, strategy):\n",
    "    \"\"\"Encode dataset using a specified missing data handling strategy.\"\"\"\n",
    "    df_w = df_in.drop(columns=['CarbonEmission']).copy()\n",
    "    \n",
    "    if strategy == 'drop_rows':\n",
    "        df_w = df_w.dropna().reset_index(drop=True)\n",
    "    elif strategy == 'drop_column':\n",
    "        df_w = df_w.drop(columns=['Vehicle Type'])\n",
    "    elif strategy == 'encode_none':\n",
    "        df_w['Vehicle Type'] = df_w['Vehicle Type'].fillna('none')\n",
    "    \n",
    "    # Parse multi-value columns\n",
    "    for item in ['Paper', 'Plastic', 'Glass', 'Metal']:\n",
    "        df_w[f'recycles_{item.lower()}'] = df_w['Recycling'].apply(lambda x: 1 if item in x else 0)\n",
    "    df_w.drop(columns=['Recycling'], inplace=True)\n",
    "    for item in ['Stove', 'Oven', 'Microwave', 'Grill', 'Airfryer']:\n",
    "        df_w[f'cooks_{item.lower()}'] = df_w['Cooking_With'].apply(lambda x: 1 if item in x else 0)\n",
    "    df_w.drop(columns=['Cooking_With'], inplace=True)\n",
    "    \n",
    "    # Ordinal encoding\n",
    "    ordinal_maps = {\n",
    "        'How Often Shower': ['less frequently', 'daily', 'more frequently', 'twice a day'],\n",
    "        'Waste Bag Size': ['small', 'medium', 'large', 'extra large'],\n",
    "        'Frequency of Traveling by Air': ['never', 'rarely', 'frequently', 'very frequently'],\n",
    "        'Energy efficiency': ['No', 'Sometimes', 'Yes'],\n",
    "        'Social Activity': ['never', 'sometimes', 'often']\n",
    "    }\n",
    "    for col, order in ordinal_maps.items():\n",
    "        df_w[col] = df_w[col].map({v: i for i, v in enumerate(order)})\n",
    "    \n",
    "    # One-hot encoding\n",
    "    nominal_cols = [c for c in ['Body Type', 'Sex', 'Diet', 'Heating Energy Source', 'Transport', 'Vehicle Type'] if c in df_w.columns]\n",
    "    df_w = pd.get_dummies(df_w, columns=nominal_cols, drop_first=True)\n",
    "    \n",
    "    scaler = StandardScaler()\n",
    "    X = scaler.fit_transform(df_w)\n",
    "    return X\n",
    " \n",
    "# Run K-Means (k=4) under each strategy\n",
    "strategies = {\n",
    "    'encode_none': 'Strategy 1: Encode \"none\"',\n",
    "    'drop_column': 'Strategy 2: Drop column',\n",
    "    'drop_rows':   'Strategy 3: Drop rows'\n",
    "}\n",
    " \n",
    "all_results = {}\n",
    "for strat_key, strat_name in strategies.items():\n",
    "    X = encode_dataset(df, strat_key)\n",
    "    km = KMeans(n_clusters=4, random_state=42, n_init=10)\n",
    "    labels = km.fit_predict(X)\n",
    "    sil = silhouette_score(X, labels)\n",
    "    \n",
    "    # Get CarbonEmission for each cluster\n",
    "    if strat_key == 'drop_rows':\n",
    "        ce = df.dropna()['CarbonEmission'].values\n",
    "    else:\n",
    "        ce = df['CarbonEmission'].values\n",
    "    \n",
    "    cluster_emissions = {c: ce[labels == c].mean() for c in range(4)}\n",
    "    unique, counts = np.unique(labels, return_counts=True)\n",
    "    \n",
    "    all_results[strat_key] = {'labels': labels, 'silhouette': sil, 'sizes': dict(zip(unique, counts)), 'emissions': cluster_emissions}\n",
    "    \n",
    "    print(f\"\\n{strat_name}\")\n",
    "    print(f\"  Samples: {X.shape[0]}, Features: {X.shape[1]}\")\n",
    "    print(f\"  Silhouette score: {sil:.4f}\")\n",
    "    print(f\"  Cluster sizes: {dict(zip(unique, counts))}\")\n",
    "    print(f\"  Mean emission per cluster: { {k: f'{v:.0f}' for k,v in sorted(cluster_emissions.items(), key=lambda x: x[1])} }\")"
