    "from scipy import stats\n",
    " \n",
    "complete = df[df['Vehicle Type'].notna()]\n",
    "incomplete = df[df['Vehicle Type'].isna()]\n",
    " \n",
    "# T-tests for numerical features\n",
    "print(\"=== T-TESTS: Numerical Features (Vehicle Type present vs absent) ===\\n\")\n",
    "print(f\"{'Feature':<35} {'Mean (present)':>15} {'Mean (absent)':>15} {'t-stat':>10} {'p-value':>10} {'Verdict':>10}\")\n",
    "print(\"-\" * 100)\n",
    " \n",
    "num_features = ['Monthly Grocery Bill', 'Vehicle Monthly Distance Km', 'Waste Bag Weekly Count',\n",
    "                'How Long TV PC Daily Hour', 'How Many New Clothes Monthly', 'How Long Internet Daily Hour',\n",
    "                'CarbonEmission']\n",
    " \n",
    "for feat in num_features:\n",
    "    t_stat, p_val = stats.ttest_ind(complete[feat], incomplete[feat])\n",
    "    sig = 'SIG ***' if p_val < 0.001 else ('SIG **' if p_val < 0.01 else ('SIG *' if p_val < 0.05 else 'n.s.'))\n",
    "    print(f\"{feat:<35} {complete[feat].mean():>15.1f} {incomplete[feat].mean():>15.1f} {t_stat:>10.2f} {p_val:>10.4f} {sig:>10}\")\n",
