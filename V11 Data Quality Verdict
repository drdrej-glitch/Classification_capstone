    "# Chi-squared tests for categorical features\n",
    "print(f\"\\n=== CHI-SQUARED TESTS: Categorical Features ===\\n\")\n",
    "cat_features = ['Body Type', 'Sex', 'Diet', 'How Often Shower', 'Heating Energy Source',\n",
    "                'Social Activity', 'Waste Bag Size', 'Frequency of Traveling by Air',\n",
